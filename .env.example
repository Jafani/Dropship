# Firebase Configuration
# Get these values from Firebase Console -> Project settings -> Your apps -> Firebase SDK snippet

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
# Storage bucket can be either:
# - your_project_id.firebasestorage.app (new Firebase projects)
# - your_project_id.appspot.com (older projects)
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Instructions:
# 1. Copy this file to .env (don't commit .env)
# 2. Replace the values with your Firebase project credentials
# 3. This file is optional and only needed for local development
# 4. For browser-only setup, just add VITE_FIREBASE_CONFIG and FIREBASE_SERVICE_ACCOUNT as repository secrets in GitHub
